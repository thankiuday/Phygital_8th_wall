# Vercel API service — copy from deploy/env/server.env.render.local
# Project: phygital-api (Root Directory = server)
#
# Vercel auto-sets VERCEL_URL (e.g. phygital-api.vercel.app).
# Set API_PUBLIC_URL to your production API domain after first deploy.

NODE_ENV=production

# SPA client origin (login cookies, OAuth return, emails)
CLIENT_URL=https://phygital-client.vercel.app

# Public API origin for media proxy URLs (no trailing slash)
API_PUBLIC_URL=https://phygital-api.vercel.app

# Google OAuth — add Authorized redirect URI in Google Cloud:
#   https://phygital-api.vercel.app/api/auth/google/callback
# GOOGLE_REDIRECT_URI=   (optional — derived from VERCEL_URL if unset)

MONGO_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PHYGITAL_QR_MONTHLY=
STRIPE_PRICE_PHYGITAL_QR_YEARLY=

# Optional — leave unset on Vercel (no background workers; API uses direct scan/render paths)
# REDIS_URL=

# Optional SMTP, Cloudinary, etc. — same as Render
