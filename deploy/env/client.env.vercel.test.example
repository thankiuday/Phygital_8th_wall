# Vercel TEST stack — three separate projects (like Render)
# See deploy/VERCEL.md
#
# phygital-api   → Root Directory: server
# phygital-client → Root Directory: client
# phygital-ar    → Root Directory: ar-engine
#
# Replace YOUR-* after first deploy, then redeploy all three.

# phygital-api (server) — copy secrets from server.env.render.local
CLIENT_URL=https://YOUR-CLIENT.vercel.app
API_PUBLIC_URL=https://YOUR-API.vercel.app

# phygital-client
VITE_API_URL=https://YOUR-API.vercel.app/api
VITE_APP_URL=https://YOUR-CLIENT.vercel.app
VITE_AR_ENGINE_URL=https://YOUR-AR.vercel.app
VITE_APP_NAME=Phygital (Test)

# phygital-ar
# VITE_API_URL=https://YOUR-API.vercel.app/api
