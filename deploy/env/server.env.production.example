# Copy to /root/phygital-server.env on the VPS

NODE_ENV=production
PORT=5000

MONGO_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

CLIENT_URL=https://phygital.zone
API_PUBLIC_URL=https://phygital.zone

# Puppeteer card PNG export (print step)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=

# Optional — local Redis: redis://127.0.0.1:6379
# REDIS_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://phygital.zone/api/auth/google/callback

# Stripe Billing (live — same values as Render production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PHYGITAL_QR_MONTHLY=price_...
STRIPE_PRICE_PHYGITAL_QR_YEARLY=price_...
